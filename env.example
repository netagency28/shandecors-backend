# Database
DATABASE_URL="postgresql://username:password@localhost:5432/shandecor"

# Supabase
SUPABASE_URL="your-supabase-url"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Cashfree Payment
PAYMENT_GATEWAY="cashfree"
ENABLE_CASHFREE="true"
CASHFREE_CLIENT_ID="your-cashfree-client-id"
CASHFREE_CLIENT_SECRET="your-cashfree-client-secret"
CASHFREE_ENVIRONMENT="sandbox"
CASHFREE_API_VERSION="2023-08-01"

# Instamojo Payment
ENABLE_INSTAMOJO="false"
INSTAMOJO_CLIENT_ID="your-instamojo-client-id"
INSTAMOJO_CLIENT_SECRET="your-instamojo-client-secret"
INSTAMOJO_ENVIRONMENT="test"
# Optional overrides if your account/docs use different endpoints
INSTAMOJO_TOKEN_URL=""
INSTAMOJO_API_BASE_URL=""

# Resend Email
RESEND_API_KEY="your-resend-api-key"
SENDER_EMAIL="your-email@example.com"

# Supabase Storage
SUPABASE_STORAGE_URL="your-supabase-storage-url"
SUPABASE_STORAGE_BUCKET="your-storage-bucket-name"

# Server
PORT=8000
NODE_ENV=development
BACKEND_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:3000"

# AI Services
ANTHROPIC_API_KEY="your-anthropic-key"
OPENAI_API_KEY="your-openai-key"
GOOGLE_AI_API_KEY="your-google-ai-key"
